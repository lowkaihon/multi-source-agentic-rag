# OpenAI (required for embeddings + generation)
OPENAI_API_KEY=sk-...

# Tavily (optional — web search fallback)
TAVILY_API_KEY=tvly-...

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=msrag-dev

# Redis semantic cache (Phase 4)
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CACHE_SIMILARITY_THRESHOLD=0.95
CORPUS_VERSION=v1

# Infrastructure hosts (for Docker Compose / cloud deployment)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
PG_HOST=localhost
PG_PORT=5432
